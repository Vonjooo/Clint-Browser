    <string name="about_created_by">Created by</string>
    <string name="about_description">Clint is a privacy-focused Android browser built on the Android WebView engine. It strips out Google telemetry and tracking, blocks ads and trackers at the network level, and puts control back in your hands.\n\nClint is completely free and open source software, released under the GNU General Public License v3. You are free to use, study, modify, and distribute it.</string>
    <string name="about_version_info">Version: %1$s (build %2$d)\nDevice architecture: %3$s</string>
    <string name="about_license_text">Clint is licensed under the GNU General Public License v3.0. This means you are free to view, modify, and redistribute the source code under the same license.</string>
    <string name="about_license_link_label">View GPL v3.0 license \u2197</string>
    <string name="about_opensource_text">The full source code is publicly available on GitHub. Contributions, bug reports, and feature requests are welcome.</string>
    <string name="about_github_url">github.com/jhaiian/Clint-Browser \u2197</string>
    <string name="about_donate_text">Clint is built and maintained in free time. If it\'s useful to you, consider supporting its development.</string>
    <string name="about_kofi_url">ko-fi.com/jhaiian \u2197</string>
    <string name="about_paypal_email">jhaiianbetter@gmail.com \u2197</string>
    <string name="doh_title">DNS over HTTPS</string>
    <string name="doh_settings_summary">Encrypt DNS lookups for privacy</string>
    <string name="doh_setup_title">Secure DNS</string>
    <string name="doh_description">DNS over HTTPS (DoH) pre-resolves domain names through an encrypted resolver before your browser connects. This hides your DNS lookups from your ISP and network. Works alongside your browser engine without affecting site compatibility.</string>
    <string name="doh_mode_label">PROTECTION LEVEL</string>
    <string name="doh_provider_label">DNS PROVIDER</string>
    <string name="doh_mode_off">Off</string>
    <string name="doh_mode_off_desc">Your device uses its default DNS resolver. No encryption.</string>
    <string name="doh_mode_default">Default Protection</string>
    <string name="doh_mode_default_desc">Domains are pre-resolved via your provider. Falls back to system DNS automatically if the provider is unavailable.</string>
    <string name="doh_mode_increased">Increased Protection</string>
    <string name="doh_mode_increased_desc">Uses your selected provider. Minimal fallback \u2014 only if the provider has a problem</string>
    <string name="doh_mode_max">Max Protection</string>
    <string name="doh_mode_max_desc">Domains are pre-resolved only via your provider. DNS lookups will fail if the provider is unreachable.</string>
    <string name="doh_provider_cloudflare">Cloudflare</string>
    <string name="doh_provider_cloudflare_desc">1.1.1.1 \u2014 Fast, privacy-first resolver by Cloudflare</string>
    <string name="doh_provider_quad9">Quad9</string>
    <string name="doh_provider_quad9_desc">9.9.9.9 \u2014 Security-focused resolver with malware blocking</string>
